FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    # UV_CACHE_DIR is useful if we mount a cache volume
    UV_CACHE_DIR=/root/.cache/uv

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /workspace/requirements.txt
COPY pyproject.toml /workspace/pyproject.toml
COPY ruff.toml /workspace/ruff.toml
COPY pytest.ini /workspace/pytest.ini

# Use uv for faster install
RUN uv pip install --system -r /workspace/requirements.txt
RUN uv pip install --system -e /workspace || true
